/* Kyria Rev3 right half overlay with Cirque Pinnacle trackpad */

/* Cirque Pinnacle trackpad node */
cirque_trackpad: cirque@42 {
    compatible = "cirque,pinnacle";       /* Cirque Pinnacle compatible device */
    reg = <0x42>;                          /* I2C address of the device */
    gpios-int = <&gpio0 15 GPIO_ACTIVE_LOW>;  /* INT pin, use any free GPIO on right half */
    i2c = <&i2c0>;                         /* Reference existing I2C0 controller on nice!nano */
};
