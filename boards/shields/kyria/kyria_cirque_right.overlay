&i2c0 {
    status = "okay";
    pinctrl-0 = <NRF_P0_27_SDA I2C>;
    pinctrl-1 = <NRF_P0_26_SCL I2C>;
    pinctrl-names = "default", "sleep";

    cirque_pinnacle: pinnacle@2a {
        compatible = "cirque,pinnacle";
        reg = <0x2a>;
        status = "okay";
    };
};

/ {
    cirque_listener {
        compatible = "zmk,input-listener";
        device = <&cirque_pinnacle>;
    };
};
