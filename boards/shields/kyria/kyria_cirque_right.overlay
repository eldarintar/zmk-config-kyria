/* kyria_cirque_right.overlay - Right half trackpad for Kyria Rev3 */

&i2c0 {
    status = "okay";
};

cirque_trackpad: cirque@42 {
    compatible = "cirque,pinnacle";
    reg = <0x42>;                         /* I2C address of trackpad */
    gpios-int = <&gpio0 15 GPIO_ACTIVE_LOW>; /* INT pin from right half */
    i2c = <&i2c0>;                        /* Reference labeled I2C controller */
};
